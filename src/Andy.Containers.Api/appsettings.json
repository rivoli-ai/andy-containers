{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=andy_containers;Username=postgres;Password=postgres"
  },
  "Auth": {
    "Authority": "https://auth.rivoli.ai",
    "Audience": "andy-containers"
  },
  "Cors": {
    "Origins": [
      "https://localhost:5280",
      "https://localhost:4200",
      "https://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "andy-containers-api",
    "OtlpEndpoint": ""
  },
  "HealthCheck": {
    "IntervalSeconds": 60
  },
  "Rbac": {
    "BaseUrl": "https://localhost:5300"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
