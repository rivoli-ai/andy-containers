{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=andy_containers;Username=postgres;Password=postgres"
  },
  "Database": {
    "_comment": "PostgreSQL is the hosted/Docker default. Conductor's embedded launcher overrides this with Database__Provider=Sqlite via environment variables.",
    "Provider": "PostgreSql"
  },
  "AndyAuth": {
    "Authority": "",
    "Audience": "urn:andy-containers-api"
  },
  "Cors": {
    "Origins": [
      "https://localhost:5280",
      "https://localhost:4200",
      "https://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "andy-containers-api",
    "OtlpEndpoint": ""
  },
  "HealthCheck": {
    "IntervalSeconds": 60
  },
  "Rbac": {
    "ApiBaseUrl": "https://localhost:7003",
    "ApplicationCode": "containers"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "CodeAssistant": {
    "DefaultLlmBaseUrl": "https://api.openai.com/v1",
    "DefaultLlmModel": "gpt-4o-mini",
    "DefaultEmbeddingBaseUrl": "https://api.openai.com/v1",
    "DefaultEmbeddingModel": "text-embedding-3-small"
  }
}
