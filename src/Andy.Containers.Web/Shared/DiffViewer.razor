@if (string.IsNullOrEmpty(Original) && string.IsNullOrEmpty(Modified))
{
    <div class="diff-empty" style="padding: 1rem; color: var(--text-muted); text-align: center;">
        No content to compare.
    </div>
}
else if (Original == Modified)
{
    <div class="diff-no-changes" style="padding: 1rem; color: var(--text-muted); text-align: center;">
        <i class="bi bi-check-circle"></i> No changes
    </div>
}
else
{
    <div class="diff-viewer" style="font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', monospace; font-size: 0.85rem; overflow: auto; max-height: @MaxHeight;">
        @foreach (var line in _diffLines)
        {
            <div class="diff-line @line.CssClass" style="padding: 0.125rem 0.75rem; white-space: pre; border-left: 3px solid @line.BorderColor;">
                <span class="diff-prefix" style="display: inline-block; width: 1.5rem; color: @line.PrefixColor; user-select: none;">@line.Prefix</span>@line.Text
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Original { get; set; } = "";
    [Parameter] public string Modified { get; set; } = "";
    [Parameter] public string MaxHeight { get; set; } = "300px";

    private List<DiffLine> _diffLines = [];

    protected override void OnParametersSet()
    {
        _diffLines = ComputeDiff(Original ?? "", Modified ?? "");
    }

    private static List<DiffLine> ComputeDiff(string original, string modified)
    {
        var oldLines = original.Split('\n');
        var newLines = modified.Split('\n');
        var result = new List<DiffLine>();

        // Simple LCS-based diff
        var lcs = ComputeLcs(oldLines, newLines);
        int oi = 0, ni = 0, li = 0;

        while (oi < oldLines.Length || ni < newLines.Length)
        {
            if (li < lcs.Count && oi < oldLines.Length && ni < newLines.Length && oldLines[oi] == lcs[li] && newLines[ni] == lcs[li])
            {
                result.Add(new DiffLine(" ", oldLines[oi], "diff-context", "transparent", "var(--text-muted)"));
                oi++; ni++; li++;
            }
            else if (oi < oldLines.Length && (li >= lcs.Count || oldLines[oi] != lcs[li]))
            {
                result.Add(new DiffLine("-", oldLines[oi], "diff-removed", "var(--danger)", "var(--danger)"));
                oi++;
            }
            else if (ni < newLines.Length && (li >= lcs.Count || newLines[ni] != lcs[li]))
            {
                result.Add(new DiffLine("+", newLines[ni], "diff-added", "var(--success)", "var(--success)"));
                ni++;
            }
            else
            {
                break; // Safety
            }
        }

        return result;
    }

    private static List<string> ComputeLcs(string[] a, string[] b)
    {
        int m = a.Length, n = b.Length;
        var dp = new int[m + 1, n + 1];
        for (int i = 1; i <= m; i++)
            for (int j = 1; j <= n; j++)
                dp[i, j] = a[i - 1] == b[j - 1] ? dp[i - 1, j - 1] + 1 : Math.Max(dp[i - 1, j], dp[i, j - 1]);

        var result = new List<string>();
        int x = m, y = n;
        while (x > 0 && y > 0)
        {
            if (a[x - 1] == b[y - 1]) { result.Add(a[x - 1]); x--; y--; }
            else if (dp[x - 1, y] > dp[x, y - 1]) x--;
            else y--;
        }
        result.Reverse();
        return result;
    }

    private record DiffLine(string Prefix, string Text, string CssClass, string BorderColor, string PrefixColor);
}
