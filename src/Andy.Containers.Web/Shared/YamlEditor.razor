@implements IAsyncDisposable
@inject IJSRuntime JS

<div id="@_editorId" class="yaml-editor-container" style="height: @Height; border: 1px solid var(--border); border-radius: 6px; overflow: hidden;"></div>

@code {
    private string _editorId = $"yaml-editor-{Guid.NewGuid():N}";
    private DotNetObjectReference<YamlEditor>? _dotNetRef;
    private bool _initialized;

    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public string Height { get; set; } = "500px";
    [Parameter] public List<EditorMarker>? Errors { get; set; }
    [Parameter] public List<EditorMarker>? Warnings { get; set; }
    [Parameter] public EventCallback<string> OnChanged { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("yamlEditor.init", _editorId, _dotNetRef, new
            {
                value = Value,
                readOnly = ReadOnly,
                height = Height
            });
            _initialized = true;
            await UpdateDiagnostics();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized)
        {
            await UpdateDiagnostics();
        }
    }

    private async Task UpdateDiagnostics()
    {
        if (!_initialized) return;

        var diagnostics = new List<object>();
        if (Errors is not null)
        {
            foreach (var e in Errors)
                diagnostics.Add(new { line = e.Line, message = e.Message, severity = "error" });
        }
        if (Warnings is not null)
        {
            foreach (var w in Warnings)
                diagnostics.Add(new { line = w.Line, message = w.Message, severity = "warning" });
        }

        try
        {
            await JS.InvokeVoidAsync("yamlEditor.setDiagnostics", _editorId, diagnostics);
        }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public async Task OnEditorChanged(string value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
        await OnChanged.InvokeAsync(value);
    }

    [JSInvokable]
    public async Task OnSaveRequested()
    {
        await OnSave.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_initialized)
        {
            try
            {
                await JS.InvokeVoidAsync("yamlEditor.dispose", _editorId);
            }
            catch (JSDisconnectedException) { }
        }
        _dotNetRef?.Dispose();
    }
}
