<div class="dependency-manager">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <div style="display: flex; gap: 0.5rem; align-items: center;">
            <button class="btn btn-primary btn-sm" @onclick="ShowAddForm" disabled="@_showForm">
                <i class="bi bi-plus-lg"></i> Add Dependency
            </button>
            <span class="text-muted" style="font-size: 0.85rem;">@Dependencies.Count dependencies</span>
        </div>
        <div style="display: flex; gap: 0.25rem;">
            <button class="btn-action @(_viewMode == "table" ? "btn-primary" : "")" @onclick='() => _viewMode = "table"' title="Table view">
                <i class="bi bi-table"></i>
            </button>
            <button class="btn-action @(_viewMode == "cards" ? "btn-primary" : "")" @onclick='() => _viewMode = "cards"' title="Card view">
                <i class="bi bi-grid-3x3-gap"></i>
            </button>
        </div>
    </div>

    @if (_showForm)
    {
        <div class="card" style="margin-bottom: 1rem;">
            <div class="card-body">
                <h5 style="margin-bottom: 1rem;">@(_editIndex >= 0 ? "Edit" : "Add") Dependency</h5>
                <div style="display: grid; grid-template-columns: 1fr 2fr 2fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                    <div>
                        <label class="form-label">Type</label>
                        <select class="form-control" @bind="_formItem.Type">
                            <option value="sdk">SDK</option>
                            <option value="runtime">Runtime</option>
                            <option value="compiler">Compiler</option>
                            <option value="tool">Tool</option>
                            <option value="library">Library</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="_formItem.Name" placeholder="e.g. dotnet-sdk" />
                    </div>
                    <div>
                        <label class="form-label">Version Constraint</label>
                        <input class="form-control" @bind="_formItem.VersionConstraint" placeholder='e.g. "8.0.*", "latest"' />
                    </div>
                </div>
                <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 0.75rem;">
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem;">
                        <input type="checkbox" @bind="_formItem.AutoUpdate" /> Auto-update
                    </label>
                    @if (_formItem.AutoUpdate)
                    {
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <label class="form-label" style="margin: 0; font-size: 0.85rem;">Policy:</label>
                            <select class="form-control" style="max-width: 150px; padding: 0.375rem 0.5rem;" @bind="_formItem.UpdatePolicy">
                                <option value="security">Security</option>
                                <option value="patch">Patch</option>
                                <option value="minor">Minor</option>
                                <option value="major">Major</option>
                                <option value="manual">Manual</option>
                            </select>
                        </div>
                    }
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button class="btn btn-primary btn-sm" @onclick="SubmitForm" disabled="@(string.IsNullOrWhiteSpace(_formItem.Name))">
                        @(_editIndex >= 0 ? "Update" : "Add")
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="CancelForm">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (Dependencies.Count == 0 && !_showForm)
    {
        <div class="empty-state" style="padding: 2rem;">
            <i class="bi bi-boxes"></i>
            <p>No dependencies declared. Click "Add Dependency" to get started.</p>
        </div>
    }
    else if (_viewMode == "table" && Dependencies.Count > 0)
    {
        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Name</th>
                        <th>Version Constraint</th>
                        <th>Status</th>
                        <th>Auto-Update</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Dependencies.Count; i++)
                    {
                        var dep = Dependencies[i];
                        var idx = i;
                        <tr>
                            <td>
                                <i class="@GetTypeIcon(dep.Type)" style="margin-right: 0.5rem; color: var(--text-muted);"></i>
                                <span style="text-transform: capitalize;">@dep.Type</span>
                            </td>
                            <td><strong class="text-mono">@dep.Name</strong></td>
                            <td class="text-mono">@dep.VersionConstraint</td>
                            <td><span class="status-badge @GetStatusClass(dep.Status)">@GetStatusLabel(dep.Status)</span></td>
                            <td>
                                @if (dep.AutoUpdate)
                                {
                                    <span style="color: var(--success);"><i class="bi bi-check-circle-fill"></i> @(dep.UpdatePolicy ?? "patch")</span>
                                }
                                else
                                {
                                    <span class="text-muted">Off</span>
                                }
                            </td>
                            <td style="text-align: right; white-space: nowrap;">
                                <button class="btn-action btn-info" @onclick="() => StartEdit(idx)" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn-action btn-danger" @onclick="() => ConfirmRemove(idx)" title="Remove">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (_viewMode == "cards" && Dependencies.Count > 0)
    {
        <div class="card-grid">
            @for (int i = 0; i < Dependencies.Count; i++)
            {
                var dep = Dependencies[i];
                var idx = i;
                <div class="card" style="border-left: 4px solid @GetStatusColor(dep.Status);">
                    <div class="card-body" style="padding: 1rem;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                            <div>
                                <strong class="text-mono">@dep.Name</strong>
                                <br />
                                <span class="info-badge" style="margin-top: 0.25rem;"><i class="@GetTypeIcon(dep.Type)"></i> @dep.Type</span>
                            </div>
                            <div style="display: flex; gap: 0.25rem;">
                                <button class="btn-action btn-info" @onclick="() => StartEdit(idx)" title="Edit"><i class="bi bi-pencil"></i></button>
                                <button class="btn-action btn-danger" @onclick="() => ConfirmRemove(idx)" title="Remove"><i class="bi bi-trash"></i></button>
                            </div>
                        </div>
                        <div class="detail-row"><strong>Version:</strong> <span class="text-mono">@dep.VersionConstraint</span></div>
                        @if (dep.ResolvedVersion is not null)
                        {
                            <div class="detail-row"><strong>Resolved:</strong> <span class="text-mono">@dep.ResolvedVersion</span></div>
                        }
                        <div style="margin-top: 0.5rem;">
                            <span class="status-badge @GetStatusClass(dep.Status)">@GetStatusLabel(dep.Status)</span>
                            @if (dep.AutoUpdate)
                            {
                                <span class="info-badge" style="margin-left: 0.5rem;"><i class="bi bi-arrow-repeat"></i> @(dep.UpdatePolicy ?? "patch")</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (_confirmRemoveIndex >= 0)
    {
        <div class="alert alert-error" style="margin-top: 1rem;">
            <i class="bi bi-exclamation-triangle"></i>
            Remove dependency "@(Dependencies.Count > _confirmRemoveIndex ? Dependencies[_confirmRemoveIndex].Name : "")"?
            <button class="btn btn-danger btn-sm" style="margin-left: 0.75rem;" @onclick="ExecuteRemove">Remove</button>
            <button class="btn btn-secondary btn-sm" style="margin-left: 0.25rem;" @onclick="() => _confirmRemoveIndex = -1">Cancel</button>
        </div>
    }
</div>

@code {
    [Parameter] public List<DependencyItem> Dependencies { get; set; } = [];
    [Parameter] public EventCallback<DependencyItem> OnAdd { get; set; }
    [Parameter] public EventCallback<(int index, DependencyItem dep)> OnEdit { get; set; }
    [Parameter] public EventCallback<int> OnRemove { get; set; }

    private string _viewMode = "table";
    private bool _showForm;
    private int _editIndex = -1;
    private DependencyItem _formItem = new();
    private int _confirmRemoveIndex = -1;

    private void ShowAddForm()
    {
        _editIndex = -1;
        _formItem = new DependencyItem();
        _showForm = true;
    }

    private void StartEdit(int index)
    {
        var dep = Dependencies[index];
        _editIndex = index;
        _formItem = new DependencyItem
        {
            Type = dep.Type,
            Name = dep.Name,
            VersionConstraint = dep.VersionConstraint,
            AutoUpdate = dep.AutoUpdate,
            UpdatePolicy = dep.UpdatePolicy
        };
        _showForm = true;
    }

    private async Task SubmitForm()
    {
        if (string.IsNullOrWhiteSpace(_formItem.Name)) return;

        if (_editIndex >= 0)
        {
            await OnEdit.InvokeAsync((_editIndex, _formItem));
        }
        else
        {
            await OnAdd.InvokeAsync(_formItem);
        }

        _showForm = false;
        _editIndex = -1;
        _formItem = new();
    }

    private void CancelForm()
    {
        _showForm = false;
        _editIndex = -1;
        _formItem = new();
    }

    private void ConfirmRemove(int index)
    {
        _confirmRemoveIndex = index;
    }

    private async Task ExecuteRemove()
    {
        if (_confirmRemoveIndex >= 0)
        {
            await OnRemove.InvokeAsync(_confirmRemoveIndex);
            _confirmRemoveIndex = -1;
        }
    }

    public static string GetTypeIcon(string type) => type.ToLowerInvariant() switch
    {
        "sdk" => "bi bi-box-seam",
        "runtime" => "bi bi-play-circle",
        "compiler" => "bi bi-gear",
        "tool" => "bi bi-wrench",
        "library" => "bi bi-book",
        _ => "bi bi-box"
    };

    public static string GetStatusClass(DependencyStatus status) => status switch
    {
        DependencyStatus.Resolved => "running",
        DependencyStatus.UpdateAvailable => "pending",
        DependencyStatus.ConstraintViolation => "failed",
        _ => "unknown"
    };

    public static string GetStatusLabel(DependencyStatus status) => status switch
    {
        DependencyStatus.Resolved => "Resolved",
        DependencyStatus.UpdateAvailable => "Update available",
        DependencyStatus.ConstraintViolation => "Constraint violation",
        _ => "Not resolved"
    };

    public static string GetStatusColor(DependencyStatus status) => status switch
    {
        DependencyStatus.Resolved => "var(--success)",
        DependencyStatus.UpdateAvailable => "var(--warning)",
        DependencyStatus.ConstraintViolation => "var(--danger)",
        _ => "var(--text-muted)"
    };
}
