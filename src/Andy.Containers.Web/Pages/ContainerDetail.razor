@page "/containers/{Id:guid}"
@inject ContainersApiService Api
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Container Detail - Andy Containers</PageTitle>

<div class="page-header">
    <h1>Container Detail</h1>
    <div style="display: flex; gap: 0.5rem;">
        <button class="btn btn-secondary btn-sm" @onclick="RefreshAsync" disabled="@_loading">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
        <a href="containers" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Containers
        </a>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div></div>
}
else if (_error is not null)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        Failed to load container: @_error
        <button class="btn btn-sm btn-secondary" @onclick="LoadContainerAsync">Retry</button>
    </div>
}
else if (_container is not null)
{
    @* ───── Stuck / Failed Warning ───── *@
    @if (_container.Status is "Creating" or "Pending")
    {
        var age = DateTime.UtcNow - _container.CreatedAt;
        @if (age.TotalMinutes > 2)
        {
            <div class="alert alert-error" style="margin-bottom: 1.5rem;">
                <i class="bi bi-exclamation-triangle"></i>
                <div>
                    <strong>This container appears stuck in "@_container.Status" status</strong> (created @FormatAge(age) ago).
                    Provisioning likely failed silently. Check the Events section below for details, then Destroy and recreate.
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success" style="margin-bottom: 1.5rem; background: rgba(0, 164, 220, 0.1); border-color: rgba(0, 164, 220, 0.3); color: var(--accent);">
                <i class="bi bi-hourglass-split"></i>
                Container is starting... (auto-refreshing every 3 seconds)
            </div>
        }
    }
    @if (_container.Status is "Failed")
    {
        <div class="alert alert-error" style="margin-bottom: 1.5rem;">
            <i class="bi bi-x-circle"></i>
            <div>
                <strong>Provisioning failed.</strong> Check the Events section below for details.
            </div>
        </div>
    }

    @* ───── Overview Card ───── *@
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
            <h5>Overview</h5>
            <div class="detail-row"><strong>Name:</strong> @_container.Name</div>
            <div class="detail-row"><strong>Status:</strong> <StatusBadge Status="@_container.Status" /></div>
            <div class="detail-row"><strong>ID:</strong> <span class="text-mono">@_container.Id</span></div>
            @if (!string.IsNullOrEmpty(_container.ExternalId))
            {
                <div class="detail-row"><strong>External ID:</strong> <span class="text-mono">@_container.ExternalId</span></div>
            }
            <div class="detail-row"><strong>Owner:</strong> @_container.OwnerId</div>
            <div class="detail-row"><strong>Template ID:</strong> <span class="text-mono">@_container.TemplateId</span></div>
            <div class="detail-row"><strong>Provider ID:</strong> <span class="text-mono">@_container.ProviderId</span></div>
            @if (!string.IsNullOrEmpty(_container.GitRepository))
            {
                <div class="detail-row"><strong>Git Repository:</strong> @_container.GitRepository</div>
            }
            <div class="detail-row"><strong>Created:</strong> @_container.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
            @if (_container.StartedAt.HasValue)
            {
                <div class="detail-row"><strong>Started:</strong> @_container.StartedAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</div>
            }
            @if (_container.StoppedAt.HasValue)
            {
                <div class="detail-row"><strong>Stopped:</strong> @_container.StoppedAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</div>
            }
            @if (_container.ExpiresAt.HasValue)
            {
                <div class="detail-row"><strong>Expires:</strong> @_container.ExpiresAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</div>
            }
            @if (_container.LastActivityAt.HasValue)
            {
                <div class="detail-row"><strong>Last Activity:</strong> @_container.LastActivityAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</div>
            }

            @if (_costEstimate is not null && _costEstimate.HourlyCostUsd > 0)
            {
                <div style="margin-top: 0.75rem; padding: 0.5rem 0.75rem; background: var(--surface-2); border-radius: 6px; border: 1px solid var(--border);">
                    <strong style="font-size: 0.85rem;">Estimated Cost</strong>
                    <div style="display: flex; gap: 1.5rem; align-items: baseline; margin-top: 0.25rem;">
                        <div>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Hourly</span>
                            <span style="font-weight: 600; margin-left: 0.25rem;">$@_costEstimate.HourlyCostUsd.ToString("F3")</span>
                        </div>
                        <div>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Monthly</span>
                            <span style="font-weight: 600; margin-left: 0.25rem;">$@_costEstimate.MonthlyCostUsd.ToString("F2")</span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(_costEstimate.FreeTierNote))
                    {
                        <div style="font-size: 0.8rem; color: var(--success); margin-top: 0.25rem;">@_costEstimate.FreeTierNote</div>
                    }
                </div>
            }
        </div>
    </div>

    @* ───── Connect Section (Running only) ───── *@
    @if (_container.Status is "Running")
    {
        <div class="card" style="margin-bottom: 1.5rem;">
            <div class="card-body">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                    <h5 style="margin: 0;">Connect</h5>
                    <button class="btn btn-secondary btn-sm" @onclick="LoadConnectionInfoAsync" disabled="@_connLoading">
                        @if (_connLoading)
                        {
                            <span class="spinner-sm"></span>
                        }
                        else
                        {
                            <i class="bi bi-arrow-clockwise"></i>
                        }
                        Refresh
                    </button>
                </div>

                @if (_connError is not null)
                {
                    <div class="alert alert-error">
                        <i class="bi bi-exclamation-triangle"></i>
                        @_connError
                    </div>
                }
                else if (_connLoading && _connectionInfo is null)
                {
                    <div><span class="spinner-sm"></span> Loading connection info...</div>
                }
                else if (_connectionInfo is not null)
                {
                    @* --- Terminal (web-based) --- *@
                    <div class="connect-row">
                        <span class="connect-dot @(HasExecCommand ? "available" : "unavailable")"></span>
                        <span class="connect-label">Terminal</span>
                        @if (HasExecCommand)
                        {
                            <a href="containers/@_container.Id/terminal" class="connect-value" style="color: var(--primary); text-decoration: none; font-weight: 600;">
                                Open Web Terminal
                            </a>
                            <a href="containers/@_container.Id/terminal" class="btn-copy" title="Open Terminal" style="text-decoration: none;">
                                <i class="bi bi-terminal"></i>
                            </a>
                        }
                        else
                        {
                            <span class="connect-value" style="color: var(--text-muted);">Not available</span>
                        }
                    </div>

                    @* --- CLI Exec command (copy to local terminal) --- *@
                    <div class="connect-row">
                        <span class="connect-dot @(HasExecCommand ? "available" : "unavailable")"></span>
                        <span class="connect-label">CLI</span>
                        @if (HasExecCommand)
                        {
                            <span class="connect-value">@ExecCommand</span>
                            <button class="btn-copy @CopyBtnClass("exec")"
                                    title="@CopyBtnTitle("exec")"
                                    @onclick="() => CopyToClipboardAsync(ExecCommand!, CopyFieldExec)">
                                <i class="bi @CopyIconClass("exec")"></i>
                            </button>
                        }
                        else
                        {
                            <span class="connect-value" style="color: var(--text-muted);">Not available</span>
                        }
                    </div>

                    @* --- SSH Connection (Docker only — Apple Containers use exec) --- *@
                    @if (IsDockerProvider && HasIpAddress)
                    {
                        <div class="connect-row">
                            <span class="connect-dot available"></span>
                            <span class="connect-label">SSH</span>
                            <span class="connect-value">@SshCommand <span style="color: var(--text-muted); font-size: 0.8rem;">(password: container)</span></span>
                            <button class="btn-copy @CopyBtnClass("ssh")"
                                    title="@CopyBtnTitle("ssh")"
                                    @onclick="() => CopyToClipboardAsync(SshCommand, CopyFieldSsh)">
                                <i class="bi @CopyIconClass("ssh")"></i>
                            </button>
                        </div>
                    }

                    @* --- IDE Link --- *@
                    <div class="connect-row">
                        <span class="connect-dot @(!string.IsNullOrEmpty(_connectionInfo.IdeEndpoint) ? "available" : "unavailable")"></span>
                        <span class="connect-label">IDE</span>
                        @if (!string.IsNullOrEmpty(_connectionInfo.IdeEndpoint))
                        {
                            <a href="@_connectionInfo.IdeEndpoint" target="_blank" class="connect-value" style="color: var(--primary); text-decoration: none;">
                                @_connectionInfo.IdeEndpoint
                            </a>
                            <a href="@_connectionInfo.IdeEndpoint" target="_blank" class="btn-copy" title="Open IDE" style="text-decoration: none;">
                                <i class="bi bi-box-arrow-up-right"></i>
                            </a>
                        }
                        else
                        {
                            <span class="connect-value" style="color: var(--text-muted);">Not available</span>
                        }
                    </div>

                    @* --- VNC Link --- *@
                    <div class="connect-row">
                        <span class="connect-dot @(!string.IsNullOrEmpty(_connectionInfo.VncEndpoint) ? "available" : "unavailable")"></span>
                        <span class="connect-label">VNC</span>
                        @if (!string.IsNullOrEmpty(_connectionInfo.VncEndpoint))
                        {
                            <a href="@_connectionInfo.VncEndpoint" target="_blank" class="connect-value" style="color: var(--primary); text-decoration: none;">
                                @_connectionInfo.VncEndpoint
                            </a>
                            <a href="@_connectionInfo.VncEndpoint" target="_blank" class="btn-copy" title="Open VNC" style="text-decoration: none;">
                                <i class="bi bi-box-arrow-up-right"></i>
                            </a>
                        }
                        else
                        {
                            <span class="connect-value" style="color: var(--text-muted);">Not available</span>
                        }
                    </div>

                    @* --- IP Address --- *@
                    <div class="connect-row">
                        <span class="connect-dot @(HasIpAddress ? "available" : "unavailable")"></span>
                        <span class="connect-label">IP Address</span>
                        @if (HasIpAddress)
                        {
                            <span class="connect-value">@_connectionInfo.IpAddress</span>
                            <button class="btn-copy @CopyBtnClass("ip")"
                                    title="@CopyBtnTitle("ip")"
                                    @onclick="() => CopyToClipboardAsync(_connectionInfo.IpAddress!, CopyFieldIp)">
                                <i class="bi @CopyIconClass("ip")"></i>
                            </button>
                        }
                        else
                        {
                            <span class="connect-value" style="color: var(--text-muted);">Not available</span>
                        }
                    </div>

                    @* --- Agent Endpoint --- *@
                    @if (!string.IsNullOrEmpty(_connectionInfo.AgentEndpoint))
                    {
                        <div class="connect-row">
                            <span class="connect-dot available"></span>
                            <span class="connect-label">Agent</span>
                            <span class="connect-value">@_connectionInfo.AgentEndpoint</span>
                            <button class="btn-copy @CopyBtnClass("agent")"
                                    title="@CopyBtnTitle("agent")"
                                    @onclick="() => CopyToClipboardAsync(_connectionInfo.AgentEndpoint!, CopyFieldAgent)">
                                <i class="bi @CopyIconClass("agent")"></i>
                            </button>
                        </div>
                    }

                    @if (_connectionInfo.PortMappings is { Count: > 0 })
                    {
                        <div style="margin-top: 0.75rem;">
                            <strong style="font-size: 0.85rem;">Port Mappings</strong>
                            <div class="data-table-wrapper" style="margin-top: 0.5rem;">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Container Port</th>
                                            <th>Host Port</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var pm in _connectionInfo.PortMappings)
                                        {
                                            <tr>
                                                <td class="text-mono">@pm.Key</td>
                                                <td class="text-mono">@pm.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @* ───── Quick Exec Card (Running only) ───── *@
    @if (_container.Status is "Running")
    {
        <div class="card" style="margin-bottom: 1.5rem;">
            <div class="card-body">
                <h5>Quick Exec</h5>
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <input class="form-control" style="max-width: 100%; flex: 1;"
                           placeholder="Enter command, e.g. ls /"
                           @bind="_execCommand"
                           @bind:event="oninput"
                           @onkeydown="HandleExecKeyDown" />
                    <button class="btn btn-primary btn-sm" @onclick="RunExecAsync" disabled="@(_execRunning || string.IsNullOrWhiteSpace(_execCommand))">
                        @if (_execRunning)
                        {
                            <span class="spinner-sm"></span>
                        }
                        else
                        {
                            <i class="bi bi-play-fill"></i>
                        }
                        Run
                    </button>
                </div>

                @if (_execError is not null)
                {
                    <div class="alert alert-error" style="margin-top: 1rem;">
                        <i class="bi bi-exclamation-triangle"></i>
                        @_execError
                    </div>
                }

                @if (_execResult is not null)
                {
                    <div style="margin-top: 1rem;">
                        <div class="detail-row">
                            <strong>Exit Code:</strong>
                            <span class="text-mono" style="color: @(_execResult.ExitCode == 0 ? "var(--success)" : "var(--danger)")">@_execResult.ExitCode</span>
                        </div>
                        @if (!string.IsNullOrEmpty(_execResult.StdOut))
                        {
                            <div style="margin-top: 0.5rem;">
                                <strong style="font-size: 0.85rem;">stdout</strong>
                                <pre class="text-mono" style="background: var(--surface-2); padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border); overflow-x: auto; margin: 0.25rem 0 0; white-space: pre-wrap; font-size: 0.85rem;">@_execResult.StdOut</pre>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_execResult.StdErr))
                        {
                            <div style="margin-top: 0.5rem;">
                                <strong style="font-size: 0.85rem; color: var(--danger);">stderr</strong>
                                <pre class="text-mono" style="background: rgba(220, 53, 69, 0.05); padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(220, 53, 69, 0.2); overflow-x: auto; margin: 0.25rem 0 0; white-space: pre-wrap; font-size: 0.85rem; color: var(--danger);">@_execResult.StdErr</pre>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @* ───── Actions Card ───── *@
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
            <h5>Actions</h5>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                @if (_container.Status is "Stopped" or "Pending" or "Failed")
                {
                    <button class="btn btn-sm" style="background: var(--success); color: white;"
                            @onclick="StartAsync" disabled="@_actionRunning">
                        @if (_actionRunning)
                        {
                            <span class="spinner-sm"></span>
                        }
                        <i class="bi bi-play-fill"></i> Start
                    </button>
                }
                @if (_container.Status is "Running")
                {
                    <button class="btn btn-warning btn-sm"
                            @onclick="StopAsync" disabled="@_actionRunning">
                        @if (_actionRunning)
                        {
                            <span class="spinner-sm"></span>
                        }
                        <i class="bi bi-stop-fill"></i> Stop
                    </button>
                }
                @if (_container.Status is not "Destroying" and not "Destroyed")
                {
                    <button class="btn btn-danger btn-sm"
                            @onclick="DestroyAsync" disabled="@_actionRunning">
                        @if (_actionRunning)
                        {
                            <span class="spinner-sm"></span>
                        }
                        <i class="bi bi-trash"></i> Destroy
                    </button>
                }
            </div>
        </div>
    </div>

    @if (_actionError is not null)
    {
        <div class="alert alert-error">
            <i class="bi bi-exclamation-triangle"></i>
            @_actionError
            <button class="alert-dismiss" @onclick="() => _actionError = null"><i class="bi bi-x-lg"></i></button>
        </div>
    }

    @* ───── Events Card ───── *@
    <div class="card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                <h5 style="margin: 0;">Events</h5>
                <button class="btn btn-secondary btn-sm" @onclick="LoadEventsAsync" disabled="@_eventsLoading">
                    @if (_eventsLoading)
                    {
                        <span class="spinner-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-clockwise"></i>
                    }
                    Refresh
                </button>
            </div>

            @if (_eventsLoading && _events is null)
            {
                <div><span class="spinner-sm"></span> Loading events...</div>
            }
            else if (_eventsError is not null)
            {
                <div class="alert alert-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    @_eventsError
                </div>
            }
            else if (_events is { Count: > 0 })
            {
                <div class="data-table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Event</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in _events)
                            {
                                <tr>
                                    <td class="text-muted" style="white-space: nowrap;">@evt.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>
                                        <span class="status-badge @EventBadgeClass(evt.EventType)">@evt.EventType</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(evt.Details))
                                        {
                                            <pre class="text-mono" style="background: var(--surface-2); padding: 0.5rem; border-radius: 4px; border: 1px solid var(--border); margin: 0; white-space: pre-wrap; font-size: 0.8rem; max-width: 500px;">@evt.Details</pre>
                                        }
                                        else
                                        {
                                            <span class="text-muted">&mdash;</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted" style="font-size: 0.9rem; margin: 0;">No events recorded.</p>
            }
        </div>
    </div>
}

@implements IAsyncDisposable

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ContainerDto? _container;
    private bool _loading = true;
    private string? _error;

    // Cost estimate
    private CostEstimateDto? _costEstimate;

    // Connection info
    private ConnectionInfoDto? _connectionInfo;
    private bool _connLoading;
    private string? _connError;

    // Provider info (for exec command)
    private ProviderDto? _provider;

    // Copy feedback
    private string? _copiedField;
    private Timer? _copiedTimer;

    // Copy field constants (to avoid string allocations in lambdas)
    private const string CopyFieldSsh = "ssh";
    private const string CopyFieldExec = "exec";
    private const string CopyFieldIp = "ip";
    private const string CopyFieldAgent = "agent";

    // Exec
    private string _execCommand = "";
    private bool _execRunning;
    private ExecResultDto? _execResult;
    private string? _execError;

    // Actions
    private bool _actionRunning;
    private string? _actionError;

    // Events
    private List<ContainerEventDto>? _events;
    private bool _eventsLoading;
    private string? _eventsError;

    // Auto-refresh polling
    private PeriodicTimer? _periodicTimer;
    private CancellationTokenSource? _pollingCts;

    // Computed properties for connect section
    private bool HasIpAddress => !string.IsNullOrEmpty(_connectionInfo?.IpAddress);
    private bool IsDockerProvider => _provider?.Type == "Docker";
    private string SshCommand => HasIpAddress ? $"ssh root@{_connectionInfo!.IpAddress}" : "";
    private string? ExecCommand => GetExecCommand();
    private bool HasExecCommand => !string.IsNullOrEmpty(ExecCommand);

    private string CopyBtnClass(string field) => _copiedField == field ? "copied" : "";
    private string CopyBtnTitle(string field) => _copiedField == field ? "Copied!" : "Copy to clipboard";
    private string CopyIconClass(string field) => _copiedField == field ? "bi-check-lg" : "bi-clipboard";

    protected override async Task OnInitializedAsync()
    {
        await LoadContainerAsync();
        StartPollingIfNeeded();
    }

    public ValueTask DisposeAsync()
    {
        StopPolling();
        _copiedTimer?.Dispose();
        return ValueTask.CompletedTask;
    }

    private void StartPollingIfNeeded()
    {
        if (_container?.Status is "Pending" or "Creating" && _pollingCts is null)
        {
            _pollingCts = new CancellationTokenSource();
            _periodicTimer = new PeriodicTimer(TimeSpan.FromSeconds(3));
            _ = PollLoopAsync(_pollingCts.Token);
        }
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        try
        {
            while (_periodicTimer is not null && await _periodicTimer.WaitForNextTickAsync(ct))
            {
                try
                {
                    var updated = await Api.GetContainerAsync(Id);
                    if (updated is not null)
                    {
                        _container = updated;
                        await InvokeAsync(StateHasChanged);

                        if (updated.Status is not "Pending" and not "Creating")
                        {
                            StopPolling();
                            if (updated.Status is "Running")
                            {
                                await LoadConnectionInfoAsync();
                                await InvokeAsync(StateHasChanged);
                            }
                            await LoadEventsAsync();
                        }
                    }
                }
                catch
                {
                    // ignore transient errors during polling
                }
            }
        }
        catch (OperationCanceledException)
        {
            // expected on dispose
        }
    }

    private void StopPolling()
    {
        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
        _pollingCts = null;
        _periodicTimer?.Dispose();
        _periodicTimer = null;
    }

    private async Task RefreshAsync()
    {
        await LoadContainerAsync();
    }

    private async Task LoadContainerAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _container = await Api.GetContainerAsync(Id);
            if (_container is null)
            {
                _error = "Container not found.";
                StopPolling();
            }
            else
            {
                // Always load events and cost
                _ = LoadEventsAsync();
                _ = LoadCostEstimateAsync();
                _ = LoadProviderAsync();

                if (_container.Status is "Running")
                {
                    StopPolling();
                    await LoadConnectionInfoAsync();
                }
                else if (_container.Status is "Pending" or "Creating")
                {
                    StartPollingIfNeeded();
                }
                else
                {
                    StopPolling();
                }
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadCostEstimateAsync()
    {
        if (_container?.ProviderId == Guid.Empty) return;
        try
        {
            _costEstimate = await Api.GetCostEstimateAsync(_container!.ProviderId);
        }
        catch { /* silently fail */ }
    }

    private async Task LoadProviderAsync()
    {
        if (_container?.ProviderId == Guid.Empty) return;
        try
        {
            _provider = await Api.GetProviderAsync(_container!.ProviderId);
        }
        catch { /* silently fail */ }
    }

    private async Task LoadConnectionInfoAsync()
    {
        _connLoading = true;
        _connError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _connectionInfo = await Api.GetConnectionInfoAsync(Id);
        }
        catch (Exception ex)
        {
            _connError = ex.Message;
        }
        finally
        {
            _connLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string? GetExecCommand()
    {
        if (string.IsNullOrEmpty(_container?.ExternalId))
            return null;

        var providerType = _provider?.Type ?? "";
        return providerType switch
        {
            "Docker" => $"docker exec -it {_container.ExternalId} bash",
            "AppleContainer" => $"container exec -it {_container.ExternalId} bash",
            _ => null
        };
    }

    private async Task CopyToClipboardAsync(string text, string field)
    {
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", text);
            _copiedField = field;
            StateHasChanged();

            // Reset after 2 seconds
            _copiedTimer?.Dispose();
            _copiedTimer = new Timer(_ =>
            {
                _copiedField = null;
                InvokeAsync(StateHasChanged);
            }, null, 2000, Timeout.Infinite);
        }
        catch
        {
            // clipboard API may not be available
        }
    }

    private async Task HandleExecKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_execRunning && !string.IsNullOrWhiteSpace(_execCommand))
        {
            await RunExecAsync();
        }
    }

    private async Task RunExecAsync()
    {
        if (string.IsNullOrWhiteSpace(_execCommand)) return;

        _execRunning = true;
        _execError = null;
        _execResult = null;
        StateHasChanged();

        try
        {
            _execResult = await Api.ExecAsync(Id, new ExecRequestDto { Command = _execCommand });
        }
        catch (Exception ex)
        {
            _execError = ex.Message;
        }
        finally
        {
            _execRunning = false;
        }
    }

    private async Task StartAsync()
    {
        _actionRunning = true;
        _actionError = null;
        StateHasChanged();

        try
        {
            await Api.StartContainerAsync(Id);
            await LoadContainerAsync();
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to start container: {ex.Message}";
        }
        finally
        {
            _actionRunning = false;
        }
    }

    private async Task StopAsync()
    {
        _actionRunning = true;
        _actionError = null;
        StateHasChanged();

        try
        {
            await Api.StopContainerAsync(Id);
            await LoadContainerAsync();
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to stop container: {ex.Message}";
        }
        finally
        {
            _actionRunning = false;
        }
    }

    private async Task DestroyAsync()
    {
        _actionRunning = true;
        _actionError = null;
        StateHasChanged();

        try
        {
            await Api.DestroyContainerAsync(Id);
            Navigation.NavigateTo("containers");
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to destroy container: {ex.Message}";
            _actionRunning = false;
        }
    }

    private async Task LoadEventsAsync()
    {
        _eventsLoading = true;
        _eventsError = null;
        StateHasChanged();

        try
        {
            _events = await Api.GetContainerEventsAsync(Id);
        }
        catch (Exception ex)
        {
            _eventsError = ex.Message;
        }
        finally
        {
            _eventsLoading = false;
            StateHasChanged();
        }
    }

    private static string FormatAge(TimeSpan age)
    {
        if (age.TotalDays >= 1) return $"{(int)age.TotalDays}d {age.Hours}h";
        if (age.TotalHours >= 1) return $"{(int)age.TotalHours}h {age.Minutes}m";
        return $"{(int)age.TotalMinutes}m";
    }

    private static string EventBadgeClass(string eventType) => eventType.ToLowerInvariant() switch
    {
        "failed" => "failed",
        "started" or "created" => "running",
        "stopped" => "stopped",
        "destroyed" => "destroyed",
        _ => "pending"
    };
}
