@page "/"
@inject ContainersApiService Api
@inject NavigationManager Navigation

<PageTitle>Dashboard - Andy Containers</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div></div>
}
else if (_error is not null)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        Failed to load dashboard data: @_error
        <button class="btn btn-sm btn-secondary" @onclick="LoadDataAsync">Retry</button>
    </div>
}
else
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon containers"><i class="bi bi-box"></i></div>
            <div>
                <div class="stat-value">@_containerCount</div>
                <div class="stat-label">Containers</div>
                <a href="containers" class="stat-link">View all &rarr;</a>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon providers"><i class="bi bi-hdd-rack"></i></div>
            <div>
                <div class="stat-value">@_providerCount</div>
                <div class="stat-label">Providers</div>
                <a href="providers" class="stat-link">View all &rarr;</a>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon templates"><i class="bi bi-file-earmark-code"></i></div>
            <div>
                <div class="stat-value">@_templateCount</div>
                <div class="stat-label">Templates</div>
                <a href="templates" class="stat-link">View all &rarr;</a>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon workspaces"><i class="bi bi-folder2-open"></i></div>
            <div>
                <div class="stat-value">@_workspaceCount</div>
                <div class="stat-label">Workspaces</div>
                <a href="workspaces" class="stat-link">View all &rarr;</a>
            </div>
        </div>
    </div>

    @if (_recentContainers.Any())
    {
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem;">
            <h3 style="margin: 0;">Recent Containers</h3>
            <a href="containers" class="stat-link">View all &rarr;</a>
        </div>
        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Owner</th>
                        <th>Created</th>
                        <th>Endpoints</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _recentContainers.Take(5))
                    {
                        <tr>
                            <td>
                                <a href="containers/@c.Id"><strong>@c.Name</strong></a>
                                <br />
                                <small class="text-muted text-mono">@c.Id.ToString()[..8]...</small>
                            </td>
                            <td><StatusBadge Status="@c.Status" /></td>
                            <td class="text-muted">@c.OwnerId</td>
                            <td class="text-muted">@c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(c.IdeEndpoint))
                                {
                                    <a href="@c.IdeEndpoint" target="_blank" class="endpoint-link" title="Open IDE">
                                        <i class="bi bi-code-square"></i> IDE
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(c.VncEndpoint))
                                {
                                    <a href="@c.VncEndpoint" target="_blank" class="endpoint-link" title="Open VNC">
                                        <i class="bi bi-display"></i> VNC
                                    </a>
                                }
                            </td>
                            <td style="text-align: right; white-space: nowrap;">
                                @if (c.Status is "Stopped" or "Pending" or "Failed")
                                {
                                    <button class="btn-action btn-success"
                                            @onclick="() => StartAsync(c)"
                                            disabled="@(c == _actionTarget)"
                                            title="Start">
                                        <i class="bi bi-play-fill"></i>
                                    </button>
                                }
                                @if (c.Status is "Running")
                                {
                                    <button class="btn-action btn-warning"
                                            @onclick="() => StopAsync(c)"
                                            disabled="@(c == _actionTarget)"
                                            title="Stop">
                                        <i class="bi bi-stop-fill"></i>
                                    </button>
                                }
                                @if (c.Status is not "Destroying" and not "Destroyed")
                                {
                                    <button class="btn-action btn-danger"
                                            @onclick="() => DestroyAsync(c)"
                                            disabled="@(c == _actionTarget)"
                                            title="Destroy">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_actionError is not null)
        {
            <div class="alert alert-error" style="margin-top: 1rem;">
                <i class="bi bi-exclamation-triangle"></i>
                @_actionError
                <button class="alert-dismiss" @onclick="() => _actionError = null"><i class="bi bi-x-lg"></i></button>
            </div>
        }
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _actionError;
    private int _containerCount;
    private int _providerCount;
    private int _templateCount;
    private int _workspaceCount;
    private List<ContainerDto> _recentContainers = [];
    private ContainerDto? _actionTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var containersTask = Api.GetContainersAsync(take: 5);
            var providersTask = Api.GetProvidersAsync();
            var templatesTask = Api.GetTemplatesAsync(take: 1);
            var workspacesTask = Api.GetWorkspacesAsync(take: 1);

            await Task.WhenAll(containersTask, providersTask, templatesTask, workspacesTask);

            var containers = await containersTask;
            var providers = await providersTask;
            var templates = await templatesTask;
            var workspaces = await workspacesTask;

            _containerCount = containers.TotalCount;
            _providerCount = providers.Count;
            _templateCount = templates.TotalCount;
            _workspaceCount = workspaces.TotalCount;
            _recentContainers = containers.Items;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartAsync(ContainerDto container)
    {
        _actionTarget = container;
        _actionError = null;
        StateHasChanged();

        try
        {
            await Api.StartContainerAsync(container.Id);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to start '{container.Name}': {ex.Message}";
        }
        finally
        {
            _actionTarget = null;
        }
    }

    private async Task StopAsync(ContainerDto container)
    {
        _actionTarget = container;
        _actionError = null;
        StateHasChanged();

        try
        {
            await Api.StopContainerAsync(container.Id);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to stop '{container.Name}': {ex.Message}";
        }
        finally
        {
            _actionTarget = null;
        }
    }

    private async Task DestroyAsync(ContainerDto container)
    {
        _actionTarget = container;
        _actionError = null;
        StateHasChanged();

        try
        {
            await Api.DestroyContainerAsync(container.Id);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to destroy '{container.Name}': {ex.Message}";
        }
        finally
        {
            _actionTarget = null;
        }
    }
}
