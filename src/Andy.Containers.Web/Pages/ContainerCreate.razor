@page "/containers/create"
@inject ContainersApiService Api
@inject NavigationManager Navigation

<PageTitle>New Container - Andy Containers</PageTitle>

<div class="page-header">
    <h1>New Container</h1>
    <a href="containers" class="btn btn-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Containers
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        @_error
        <button class="alert-dismiss" @onclick="() => _error = null"><i class="bi bi-x-lg"></i></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label class="form-label" for="name">Name <span class="text-danger">*</span></label>
                <InputText id="name" class="form-control" @bind-Value="_model.Name" placeholder="my-dev-container" />
                <ValidationMessage For="() => _model.Name" />
            </div>

            <div class="form-group">
                <label class="form-label" for="template">Template</label>
                @if (_loadingTemplates)
                {
                    <div><span class="spinner-sm"></span> Loading templates...</div>
                }
                else
                {
                    <InputSelect id="template" class="form-control" @bind-Value="_model.TemplateId">
                        <option value="">-- Select a template --</option>
                        @foreach (var t in _templates)
                        {
                            <option value="@t.Id">@t.Name (@t.Code) — @t.BaseImage</option>
                        }
                    </InputSelect>
                }
            </div>

            <div class="form-group">
                <label class="form-label" for="provider">Provider</label>
                @if (_loadingProviders)
                {
                    <div><span class="spinner-sm"></span> Loading providers...</div>
                }
                else
                {
                    <InputSelect id="provider" class="form-control" @bind-Value="_model.ProviderId"
                                 @bind-Value:after="OnProviderChangedAsync">
                        <option value="">Auto-select</option>
                        @foreach (var p in _providers)
                        {
                            <option value="@p.Id">@p.Name (@p.Type, @p.Region)</option>
                        }
                    </InputSelect>
                }

                @if (_costLoading)
                {
                    <div style="margin-top: 0.5rem;"><span class="spinner-sm"></span> Loading cost estimate...</div>
                }
                else if (_costEstimate is not null)
                {
                    <div style="margin-top: 0.75rem; padding: 0.75rem; background: var(--surface-2); border-radius: 6px; border: 1px solid var(--border);">
                        <div style="display: flex; gap: 1.5rem; align-items: baseline; margin-bottom: 0.5rem;">
                            <div>
                                <span style="font-size: 0.8rem; color: var(--text-muted);">Hourly</span>
                                <div style="font-size: 1.1rem; font-weight: 600;">$@_costEstimate.HourlyCostUsd.ToString("F3")</div>
                            </div>
                            <div>
                                <span style="font-size: 0.8rem; color: var(--text-muted);">Monthly (est.)</span>
                                <div style="font-size: 1.1rem; font-weight: 600;">$@_costEstimate.MonthlyCostUsd.ToString("F2")</div>
                            </div>
                        </div>
                        @if (_costEstimate.Breakdown is { Length: > 0 })
                        {
                            <div style="font-size: 0.8rem; color: var(--text-muted);">
                                @foreach (var b in _costEstimate.Breakdown)
                                {
                                    <span style="margin-right: 1rem;">@b.Component: $@b.HourlyCostUsd.ToString("F4")/hr</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_costEstimate.FreeTierNote))
                        {
                            <div style="font-size: 0.8rem; color: var(--success); margin-top: 0.25rem;">
                                @_costEstimate.FreeTierNote
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="form-group">
                <label class="form-label" for="gitUrl">Git Repository URL</label>
                <InputText id="gitUrl" class="form-control" @bind-Value="_model.GitRepositoryUrl" placeholder="https://github.com/org/repo.git" />
            </div>

            <div class="form-group">
                <label class="form-label" for="gitBranch">Git Branch</label>
                <InputText id="gitBranch" class="form-control" @bind-Value="_model.GitBranch" placeholder="main" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @if (_submitting)
                    {
                        <span class="spinner-sm"></span>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <i class="bi bi-plus-lg"></i>
                        <span>Create Container</span>
                    }
                </button>
                <a href="containers" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly ContainerCreateModel _model = new();
    private List<TemplateDto> _templates = [];
    private List<ProviderDto> _providers = [];
    private bool _loadingTemplates = true;
    private bool _loadingProviders = true;
    private bool _submitting;
    private string? _error;
    private CostEstimateDto? _costEstimate;
    private bool _costLoading;

    protected override async Task OnInitializedAsync()
    {
        var templatesTask = LoadTemplatesAsync();
        var providersTask = LoadProvidersAsync();
        await Task.WhenAll(templatesTask, providersTask);
    }

    private async Task LoadTemplatesAsync()
    {
        try
        {
            var result = await Api.GetTemplatesAsync(take: 100);
            _templates = result.Items.Where(t => t.IsPublished).ToList();
        }
        catch { /* silently fail, dropdown will be empty */ }
        finally { _loadingTemplates = false; }
    }

    private async Task LoadProvidersAsync()
    {
        try
        {
            _providers = (await Api.GetProvidersAsync()).Where(p => p.IsEnabled).ToList();
        }
        catch { /* silently fail, dropdown will be empty */ }
        finally { _loadingProviders = false; }
    }

    private async Task OnProviderChangedAsync()
    {
        _costEstimate = null;
        if (!Guid.TryParse(_model.ProviderId, out var providerId)) return;

        _costLoading = true;
        StateHasChanged();

        try
        {
            _costEstimate = await Api.GetCostEstimateAsync(providerId);
        }
        catch { /* silently fail */ }
        finally
        {
            _costLoading = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        _submitting = true;
        _error = null;
        StateHasChanged();

        try
        {
            var request = new CreateContainerRequest { Name = _model.Name };

            if (Guid.TryParse(_model.TemplateId, out var templateId))
                request.TemplateId = templateId;

            if (Guid.TryParse(_model.ProviderId, out var providerId))
                request.ProviderId = providerId;

            if (!string.IsNullOrWhiteSpace(_model.GitRepositoryUrl))
            {
                request.GitRepository = new GitRepositoryConfig
                {
                    Url = _model.GitRepositoryUrl,
                    Branch = string.IsNullOrWhiteSpace(_model.GitBranch) ? null : _model.GitBranch
                };
            }

            await Api.CreateContainerAsync(request);
            Navigation.NavigateTo("containers");
        }
        catch (Exception ex)
        {
            _error = $"Failed to create container: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private class ContainerCreateModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Container name is required.")]
        public string Name { get; set; } = "";
        public string? TemplateId { get; set; }
        public string? ProviderId { get; set; }
        public string? GitRepositoryUrl { get; set; }
        public string? GitBranch { get; set; }
    }
}
