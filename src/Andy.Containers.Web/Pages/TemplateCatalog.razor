@page "/templates"
@inject ContainersApiService Api

<PageTitle>Template Catalog - Andy Containers</PageTitle>

<div class="page-header">
    <h1>Template Catalog</h1>
    <button class="btn btn-secondary btn-sm" @onclick="LoadDataAsync" disabled="@_loading">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
</div>

<div class="filters-container">
    <input type="text"
           class="search-input"
           placeholder="Search templates..."
           @bind="_searchTerm"
           @bind:event="oninput"
           @onkeydown="OnSearchKeyDown" />
    @if (!string.IsNullOrEmpty(_searchTerm))
    {
        <button class="btn btn-secondary btn-sm" @onclick="ClearSearch">
            <i class="bi bi-x-lg"></i>
        </button>
    }
    <button class="btn btn-primary btn-sm" @onclick="SearchAsync">Search</button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div></div>
}
else if (_error is not null)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        Failed to load templates: @_error
        <button class="btn btn-sm btn-secondary" @onclick="LoadDataAsync">Retry</button>
    </div>
}
else if (!_templates.Any())
{
    <div class="empty-state">
        <i class="bi bi-file-earmark-code"></i>
        <p>
            @if (!string.IsNullOrEmpty(_activeSearch))
            {
                <span>No templates matching "@_activeSearch".</span>
            }
            else
            {
                <span>No published templates found.</span>
            }
        </p>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var t in _templates)
        {
            <div class="card">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                        <h5>@t.Name</h5>
                        <span class="info-badge">@t.Version</span>
                    </div>
                    <p class="text-muted" style="font-size: 0.9rem; margin-bottom: 0.75rem;">
                        @(t.Description ?? "No description.")
                    </p>
                    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
                        <span class="info-badge"><i class="bi bi-box-seam"></i> @t.BaseImage</span>
                        <span class="info-badge"><i class="bi bi-code-square"></i> @t.IdeType</span>
                        @if (t.GpuRequired)
                        {
                            <span class="info-badge badge-gpu-required"><i class="bi bi-gpu-card"></i> GPU Required</span>
                        }
                        else if (t.GpuPreferred)
                        {
                            <span class="info-badge badge-gpu-preferred"><i class="bi bi-gpu-card"></i> GPU Preferred</span>
                        }
                    </div>
                    <div style="margin-bottom: 0.75rem;">
                        <span class="scope-badge @t.CatalogScope.ToLowerInvariant()">@t.CatalogScope</span>
                    </div>
                    @if (t.Tags is { Length: > 0 })
                    {
                        <div>
                            @foreach (var tag in t.Tags)
                            {
                                <span class="tag-badge">@tag</span>
                            }
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <small class="text-muted" style="display: flex; justify-content: space-between;">
                        <span><i class="bi bi-tag"></i> @t.Code</span>
                        <span>@t.CreatedAt.ToString("yyyy-MM-dd")</span>
                    </small>
                </div>
            </div>
        }
    </div>

    @if (_totalCount > _templates.Count)
    {
        <div class="pagination-info">
            Showing @_templates.Count of @_totalCount templates.
        </div>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<TemplateDto> _templates = [];
    private int _totalCount;
    private string _searchTerm = "";
    private string _activeSearch = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var search = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm.Trim();
            _activeSearch = search ?? "";
            var result = await Api.GetTemplatesAsync(search: search, take: 50);
            _templates = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchAsync()
    {
        await LoadDataAsync();
    }

    private async Task ClearSearch()
    {
        _searchTerm = "";
        await LoadDataAsync();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAsync();
        }
    }
}
