@page "/workspaces"
@inject ContainersApiService Api

<PageTitle>Workspaces - Andy Containers</PageTitle>

<div class="page-header">
    <h1>Workspaces</h1>
    <button class="btn btn-secondary btn-sm" @onclick="LoadDataAsync" disabled="@_loading">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div></div>
}
else if (_error is not null)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        Failed to load workspaces: @_error
        <button class="btn btn-sm btn-secondary" @onclick="LoadDataAsync">Retry</button>
    </div>
}
else if (!_workspaces.Any())
{
    <div class="empty-state">
        <i class="bi bi-folder2-open"></i>
        <p>No workspaces found.</p>
    </div>
}
else
{
    <div class="data-table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Status</th>
                    <th>Owner</th>
                    <th>Git Repository</th>
                    <th>Default Container</th>
                    <th>Created</th>
                    <th>Last Accessed</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in _workspaces)
                {
                    <tr>
                        <td>
                            <strong>@w.Name</strong>
                            @if (!string.IsNullOrEmpty(w.Description))
                            {
                                <br />
                                <small class="text-muted">@w.Description</small>
                            }
                        </td>
                        <td><StatusBadge Status="@w.Status" /></td>
                        <td class="text-muted">@w.OwnerId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(w.GitRepositoryUrl))
                            {
                                <span class="text-mono">@w.GitRepositoryUrl</span>
                                @if (!string.IsNullOrEmpty(w.GitBranch))
                                {
                                    <br />
                                    <span class="info-badge" style="margin-top: 0.25rem;">
                                        <i class="bi bi-diagram-2"></i> @w.GitBranch
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td>
                            @if (w.DefaultContainer is not null)
                            {
                                <span>@w.DefaultContainer.Name</span>
                                <br />
                                <StatusBadge Status="@w.DefaultContainer.Status" />
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td class="text-muted">@w.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-muted">
                            @if (w.LastAccessedAt.HasValue)
                            {
                                @w.LastAccessedAt.Value.ToString("yyyy-MM-dd HH:mm")
                            }
                            else
                            {
                                <span>&mdash;</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_totalCount > _workspaces.Count)
    {
        <div class="pagination-info">
            Showing @_workspaces.Count of @_totalCount workspaces.
        </div>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private List<WorkspaceDto> _workspaces = [];
    private int _totalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var result = await Api.GetWorkspacesAsync(take: 50);
            _workspaces = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
