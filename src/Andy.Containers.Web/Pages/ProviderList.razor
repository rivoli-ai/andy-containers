@page "/providers"
@inject ContainersApiService Api

<PageTitle>Providers - Andy Containers</PageTitle>

<div class="page-header">
    <h1>Infrastructure Providers</h1>
    <button class="btn btn-secondary btn-sm" @onclick="LoadDataAsync" disabled="@_loading">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div></div>
}
else if (_error is not null)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        Failed to load providers: @_error
        <button class="btn btn-sm btn-secondary" @onclick="LoadDataAsync">Retry</button>
    </div>
}
else if (!_providers.Any())
{
    <div class="empty-state">
        <i class="bi bi-hdd-rack"></i>
        <p>No infrastructure providers configured.</p>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var p in _providers)
        {
            <div class="card" style="@(!p.IsEnabled ? "opacity: 0.6;" : "")">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                        <h5>
                            <i class="@GetProviderIcon(p.Type)" style="margin-right: 0.5rem;"></i>@p.Name
                        </h5>
                        <StatusBadge Status="@p.HealthStatus" />
                    </div>
                    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem;">
                        <span class="info-badge">@p.Type</span>
                        @if (!string.IsNullOrEmpty(p.Region))
                        {
                            <span class="info-badge"><i class="bi bi-geo-alt"></i> @p.Region</span>
                        }
                        @if (!p.IsEnabled)
                        {
                            <span class="info-badge badge-disabled">Disabled</span>
                        }
                    </div>
                    <div>
                        <div class="detail-row"><strong>Code:</strong> @p.Code</div>
                        <div class="detail-row">
                            <strong>Last check:</strong>
                            @if (p.LastHealthCheck.HasValue)
                            {
                                @p.LastHealthCheck.Value.ToString("yyyy-MM-dd HH:mm:ss")
                            }
                            else
                            {
                                <span>Never</span>
                            }
                        </div>
                        <div class="detail-row"><strong>Created:</strong> @p.CreatedAt.ToString("yyyy-MM-dd")</div>
                    </div>
                </div>
                <div class="card-footer">
                    <button class="btn btn-secondary btn-sm"
                            @onclick="() => CheckHealthAsync(p)"
                            disabled="@(_checkingHealth == p.Id)">
                        @if (_checkingHealth == p.Id)
                        {
                            <span class="spinner-sm"></span>
                        }
                        else
                        {
                            <i class="bi bi-heart-pulse"></i>
                        }
                        Check Health
                    </button>
                </div>
            </div>
        }
    </div>
}

@if (_actionError is not null)
{
    <div class="alert alert-error" style="margin-top: 1.5rem;">
        <i class="bi bi-exclamation-triangle"></i>
        @_actionError
        <button class="alert-dismiss" @onclick="() => _actionError = null"><i class="bi bi-x-lg"></i></button>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private string? _actionError;
    private List<ProviderDto> _providers = [];
    private Guid? _checkingHealth;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _providers = await Api.GetProvidersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CheckHealthAsync(ProviderDto provider)
    {
        _checkingHealth = provider.Id;
        _actionError = null;
        StateHasChanged();

        try
        {
            var result = await Api.CheckProviderHealthAsync(provider.Id);
            if (result is not null)
            {
                provider.HealthStatus = result.Status;
                provider.LastHealthCheck = DateTime.UtcNow;
            }
        }
        catch (Exception ex)
        {
            _actionError = $"Health check failed for '{provider.Name}': {ex.Message}";
        }
        finally
        {
            _checkingHealth = null;
        }
    }

    private static string GetProviderIcon(string type) => type switch
    {
        "Docker" => "bi bi-box-seam",
        "AppleContainer" => "bi bi-apple",
        "Rivoli" => "bi bi-hdd-rack",
        "Ssh" => "bi bi-terminal",
        "AzureAci" or "AzureAca" or "AzureAcp" => "bi bi-cloud",
        _ => "bi bi-hdd-rack"
    };
}
