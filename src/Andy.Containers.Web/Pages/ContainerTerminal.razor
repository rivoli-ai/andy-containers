@page "/containers/{Id:guid}/terminal"
@inject ContainersApiService Api
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Terminal - Andy Containers</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 1rem; background: var(--surface-2); border-bottom: 1px solid var(--border);">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <a href="containers/@Id" style="color: var(--text-muted); text-decoration: none;" title="Back to container">
            <i class="bi bi-arrow-left"></i>
        </a>
        <span style="font-weight: 600;">
            <i class="bi bi-terminal" style="margin-right: 0.25rem;"></i>
            @(_container?.Name ?? "Terminal")
        </span>
        @if (_container is not null)
        {
            <StatusBadge Status="@_container.Status" />
        }
    </div>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
        <span style="font-size: 0.75rem; color: var(--text-muted);">
            @if (_connected)
            {
                <span style="color: var(--success);">Connected</span>
            }
            else
            {
                <span style="color: var(--danger);">@(_error ?? "Connecting...")</span>
            }
        </span>
        <button class="btn btn-secondary btn-sm" @onclick="ClearTerminal" title="Clear">
            <i class="bi bi-trash"></i> Clear
        </button>
    </div>
</div>

<div id="terminal-output" @ref="_outputRef"
     style="flex: 1; overflow-y: auto; padding: 0.75rem 1rem; font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace; font-size: 0.85rem; line-height: 1.5; background: #1a1a2e; color: #e0e0e0; white-space: pre-wrap; word-break: break-all;">
    @if (_error is not null)
    {
        <div style="color: #ff6b6b;">@_error</div>
    }
    else
    {
        @foreach (var entry in _history)
        {
            <div>
                <span style="color: #4fc3f7;">@_prompt</span>
                <span style="color: #fff;">@entry.Command</span>
            </div>
            @if (!string.IsNullOrEmpty(entry.StdOut))
            {
                <div style="color: #e0e0e0;">@entry.StdOut</div>
            }
            @if (!string.IsNullOrEmpty(entry.StdErr))
            {
                <div style="color: #ff6b6b;">@entry.StdErr</div>
            }
            @if (entry.ExitCode != 0)
            {
                <div style="color: #ffa726; font-size: 0.75rem;">[exit code: @entry.ExitCode]</div>
            }
        }
        @if (_running)
        {
            <div>
                <span style="color: #4fc3f7;">@_prompt</span>
                <span style="color: #fff;">@_currentCommand</span>
                <span class="terminal-cursor"></span>
            </div>
        }
    }
</div>

<div style="display: flex; align-items: center; background: #16213e; border-top: 1px solid var(--border); padding: 0.5rem 1rem;">
    <span style="color: #4fc3f7; font-family: 'SF Mono', 'Menlo', monospace; font-size: 0.85rem; margin-right: 0.5rem; white-space: nowrap;">@_prompt</span>
    <input @ref="_inputRef"
           class="terminal-input"
           type="text"
           @bind="_currentCommand"
           @bind:event="oninput"
           @onkeydown="HandleKeyDown"
           disabled="@(!_connected || _running)"
           autocomplete="off"
           spellcheck="false"
           placeholder="@(_connected ? "Type a command..." : "")" />
</div>

<style>
    /* Make the terminal page fill the viewport */
    .page-content {
        display: flex !important;
        flex-direction: column !important;
        height: calc(100vh - 3.5rem) !important;
        padding: 0 !important;
        overflow: hidden !important;
    }

    .terminal-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
        font-size: 0.85rem;
        caret-color: #4fc3f7;
    }
    .terminal-input::placeholder {
        color: #555;
    }
    .terminal-input:disabled {
        opacity: 0.5;
    }

    .terminal-cursor {
        display: inline-block;
        width: 8px;
        height: 1em;
        background: #4fc3f7;
        animation: blink 1s step-end infinite;
        vertical-align: text-bottom;
    }
    @@keyframes blink {
        50% { opacity: 0; }
    }
</style>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ContainerDto? _container;
    private string? _error;
    private bool _connected;
    private bool _running;
    private string _currentCommand = "";
    private string _cwd = "/";
    private string _prompt = "root@container:/# ";

    private readonly List<TerminalEntry> _history = [];
    private readonly List<string> _commandHistory = [];
    private int _historyIndex = -1;

    private ElementReference _outputRef;
    private ElementReference _inputRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _container = await Api.GetContainerAsync(Id);
            if (_container is null)
            {
                _error = "Container not found.";
                return;
            }
            if (_container.Status != "Running")
            {
                _error = $"Container is {_container.Status}. Terminal requires a running container.";
                return;
            }
            _prompt = $"root@{_container.Name}:/# ";
            _connected = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to connect: {ex.Message}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _connected)
        {
            await FocusInput();
        }
        // Auto-scroll to bottom
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('terminal-output')?.scrollTo(0, 999999)");
        }
        catch { }
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_running && !string.IsNullOrWhiteSpace(_currentCommand))
        {
            await ExecuteCommandAsync();
        }
        else if (e.Key == "ArrowUp")
        {
            NavigateHistory(-1);
        }
        else if (e.Key == "ArrowDown")
        {
            NavigateHistory(1);
        }
        else if (e.Key == "l" && e.CtrlKey)
        {
            ClearTerminal();
        }
    }

    private void NavigateHistory(int direction)
    {
        if (_commandHistory.Count == 0) return;

        _historyIndex += direction;
        if (_historyIndex < 0) _historyIndex = 0;
        if (_historyIndex >= _commandHistory.Count)
        {
            _historyIndex = _commandHistory.Count;
            _currentCommand = "";
            return;
        }
        _currentCommand = _commandHistory[_historyIndex];
    }

    private async Task ExecuteCommandAsync()
    {
        var command = _currentCommand.Trim();
        _currentCommand = "";
        _running = true;
        StateHasChanged();

        // Track cd commands to update prompt (best effort)
        var effectiveCommand = command;
        if (_cwd != "/")
        {
            effectiveCommand = $"cd {_cwd} && {command}";
        }

        // Handle cd specially to track working directory
        if (command.StartsWith("cd "))
        {
            var target = command[3..].Trim();
            effectiveCommand = _cwd != "/"
                ? $"cd {_cwd} && cd {target} && pwd"
                : $"cd {target} && pwd";
        }

        _commandHistory.Add(command);
        _historyIndex = _commandHistory.Count;

        try
        {
            var result = await Api.ExecAsync(Id, new ExecRequestDto { Command = effectiveCommand });
            if (result is null)
            {
                _history.Add(new TerminalEntry(command, "", "No response from container", 1));
            }
            // Update cwd if it was a cd command
            else if (command.StartsWith("cd ") && result.ExitCode == 0 && !string.IsNullOrWhiteSpace(result.StdOut))
            {
                _cwd = result.StdOut.Trim();
                UpdatePrompt();
                _history.Add(new TerminalEntry(command, "", "", 0));
            }
            else
            {
                _history.Add(new TerminalEntry(command, result.StdOut ?? "", result.StdErr ?? "", result.ExitCode));
            }
        }
        catch (Exception ex)
        {
            _history.Add(new TerminalEntry(command, "", ex.Message, 1));
        }
        finally
        {
            _running = false;
            StateHasChanged();
            await FocusInput();
        }
    }

    private void UpdatePrompt()
    {
        var dir = _cwd == "/" ? "/" : _cwd;
        var name = _container?.Name ?? "container";
        _prompt = $"root@{name}:{dir}# ";
    }

    private void ClearTerminal()
    {
        _history.Clear();
        StateHasChanged();
    }

    private async Task FocusInput()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", $"document.querySelector('.terminal-input')?.focus()");
        }
        catch { }
    }

    private record TerminalEntry(string Command, string StdOut, string StdErr, int ExitCode);
}
