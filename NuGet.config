<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      Local feed for in-development Andy.Settings.Client packages produced by
      `../andy-settings/scripts/pack-local.sh` during epic/andy-settings-migration.
      The path is repo-relative and assumes sibling checkouts under rivoli-ai/.
      When the epic merges and CI starts publishing to nuget.org, this source
      becomes a harmless no-op (no matching version) — leave it in during the
      epic, remove it in a follow-up once consumers pin an rc version.
    -->
    <add key="andy-settings-local" value="../andy-settings/artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
